ECOLENS_SECRET_KEY=change-this-secret-key
ECOLENS_MYSQL_HOST=127.0.0.1
ECOLENS_MYSQL_PORT=3306
ECOLENS_MYSQL_USER=root
ECOLENS_MYSQL_PASSWORD=
ECOLENS_MYSQL_DATABASE=ecolens_db

# Optional: only used to create the first admin user when the users table is empty.
ECOLENS_ADMIN_USERNAME=admin
ECOLENS_ADMIN_PASSWORD=change-this-admin-password

# Optional runtime behavior.
ECOLENS_DEBUG=false
